{
  "surahs": [
    {
      "number": 1,
      "name_arabic": "الفاتحة",
      "name_english": "Al-Fatihah",
      "total_ayahs": 7,
      "revelation_place": "Makkah",
      "ayahs": [
        {
          "ayah_number": 1,
          "text_arabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
          "translations": [
            { "language": "english", "text": "In the name of Allah, the Entirely Merciful, the Especially Merciful." }
          ]
        },
        {
          "ayah_number": 2,
          "text_arabic": "الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ",
          "translations": [
            { "language": "english", "text": "[All] praise is [due] to Allah, Lord of the worlds -" }
          ]
        },
        {
          "ayah_number": 3,
          "text_arabic": "الرَّحْمَٰنِ الرَّحِيمِ",
          "translations": [
            { "language": "english", "text": "The Entirely Merciful, the Especially Merciful," }
          ]
        },
        {
          "ayah_number": 4,
          "text_arabic": "مَالِكِ يَوْمِ الدِّينِ",
          "translations": [
            { "language": "english", "text": "Sovereign of the Day of Recompense." }
          ]
        },
        {
          "ayah_number": 5,
          "text_arabic": "إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ",
          "translations": [
            { "language": "english", "text": "It is You we worship and You we ask for help." }
          ]
        },
        {
          "ayah_number": 6,
          "text_arabic": "اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ",
          "translations": [
            { "language": "english", "text": "Guide us to the straight path -" }
          ]
        },
        {
          "ayah_number": 7,
          "text_arabic": "صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ",
          "translations": [
            { "language": "english", "text": "The path of those upon whom You have bestowed favor, not of those who have earned [Your] anger or of those who are astray." }
          ]
        }
      ]
    }
  ]
}
